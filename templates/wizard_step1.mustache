{{!
    @template local_studiolms/wizard_step1

    Briefing step of the StudioLMS course builder wizard.

    Context variables required for this template:
    * courseid - Target course id.
    * sesskey - Session key.
    * cancelurl - URL back to the course.
    * steplabel - "Step 1 of 3" label.
    * playerhud - Whether block_playerhud is installed.
    * bloomlevels - Array of {value, label, checked} cognitive levels.
    * profiles - Array of {value, label, checked} gamification profiles.

    Example context (json):
    {
        "courseid": 5,
        "sesskey": "abc123",
        "cancelurl": "https://example.com/course/view.php?id=5",
        "steplabel": "Step 1 of 3",
        "playerhud": true,
        "bloomlevels": [
            {"value": "remember", "label": "Remember", "checked": false},
            {"value": "apply", "label": "Apply", "checked": true}
        ],
        "profiles": [
            {"value": "conquest", "label": "Conquest", "checked": false},
            {"value": "narrative", "label": "Narrative", "checked": true},
            {"value": "social", "label": "Social", "checked": false}
        ]
    }
}}
<div class="local-studiolms-wizard" id="local-studiolms-step1-wrapper">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">{{#str}}generate_heading, local_studiolms{{/str}}</h3>
        <span class="badge bg-light text-dark border">{{steplabel}}</span>
    </div>

    <form id="local-studiolms-step1" data-courseid="{{courseid}}">
        <input type="hidden" name="sesskey" value="{{sesskey}}">

        <div class="alert alert-danger d-none" role="alert" data-region="error"></div>

        <div class="mb-3">
            <label class="form-label" for="studiolms-theme">
                {{#str}}briefing_theme, local_studiolms{{/str}} <span class="text-danger">*</span>
            </label>
            <input type="text" class="form-control" id="studiolms-theme" name="theme" required
                placeholder="{{#str}}briefing_theme_placeholder, local_studiolms{{/str}}">
        </div>

        <div class="mb-3">
            <label class="form-label" for="studiolms-reference">
                {{#str}}briefing_reference, local_studiolms{{/str}}
            </label>
            <textarea class="form-control" id="studiolms-reference" name="reference" rows="4"
                placeholder="{{#str}}briefing_reference_placeholder, local_studiolms{{/str}}"></textarea>
        </div>

        <div class="row">
            <div class="col-12 col-md-4 mb-3">
                <fieldset class="card h-100">
                    <legend class="card-header h6 mb-0">{{#str}}briefing_bloom, local_studiolms{{/str}}</legend>
                    <div class="card-body">
                        {{#bloomlevels}}
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="bloom"
                                    id="studiolms-bloom-{{value}}" value="{{value}}" {{#checked}}checked{{/checked}}>
                                <label class="form-check-label" for="studiolms-bloom-{{value}}">{{label}}</label>
                            </div>
                        {{/bloomlevels}}
                    </div>
                </fieldset>
            </div>

            <div class="col-12 col-md-4 mb-3">
                <fieldset class="card h-100">
                    <legend class="card-header h6 mb-0">{{#str}}briefing_structure, local_studiolms{{/str}}</legend>
                    <div class="card-body">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="structure"
                                id="studiolms-structure-free" value="free" checked>
                            <label class="form-check-label" for="studiolms-structure-free">
                                {{#str}}structure_free, local_studiolms{{/str}}
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="structure"
                                id="studiolms-structure-abc" value="abc">
                            <label class="form-check-label" for="studiolms-structure-abc">
                                {{#str}}structure_abc, local_studiolms{{/str}}
                            </label>
                        </div>
                    </div>
                </fieldset>
            </div>

            <div class="col-12 col-md-4 mb-3">
                <fieldset class="card h-100">
                    <legend class="card-header h6 mb-0">{{#str}}briefing_mode, local_studiolms{{/str}}</legend>
                    <div class="card-body">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="mode"
                                id="studiolms-mode-standard" value="standard" checked>
                            <label class="form-check-label" for="studiolms-mode-standard">
                                {{#str}}mode_standard, local_studiolms{{/str}}
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="mode"
                                id="studiolms-mode-gamified" value="gamified" {{^playerhud}}disabled{{/playerhud}}>
                            <label class="form-check-label" for="studiolms-mode-gamified">
                                {{#str}}mode_gamified, local_studiolms{{/str}}
                            </label>
                        </div>
                        {{#playerhud}}
                            <span class="badge bg-success">{{#str}}mode_gamified_detected, local_studiolms{{/str}}</span>
                        {{/playerhud}}
                        {{^playerhud}}
                            <span class="text-muted small">{{#str}}mode_gamified_disabled, local_studiolms{{/str}}</span>
                        {{/playerhud}}

                        <fieldset class="mt-3 pt-3 border-top d-none" data-region="profiles">
                            <legend class="form-label h6">{{#str}}gamification_profile, local_studiolms{{/str}}</legend>
                            {{#profiles}}
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="profile"
                                        id="studiolms-profile-{{value}}" value="{{value}}" {{#checked}}checked{{/checked}}>
                                    <label class="form-check-label" for="studiolms-profile-{{value}}">{{label}}</label>
                                </div>
                            {{/profiles}}
                        </fieldset>
                    </div>
                </fieldset>
            </div>
        </div>

        <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" name="wipe" id="studiolms-wipe" value="1">
            <label class="form-check-label" for="studiolms-wipe">
                {{#str}}briefing_wipe, local_studiolms{{/str}}
            </label>
        </div>
        <div class="alert alert-warning d-none" role="alert" data-region="wipewarning">
            {{#str}}briefing_wipe_warning, local_studiolms{{/str}}
        </div>

        <div class="d-flex justify-content-start">
            <a class="btn btn-secondary me-2" href="{{cancelurl}}">{{#str}}btn_cancel, local_studiolms{{/str}}</a>
            <button type="submit" class="btn btn-primary" data-action="generate">
                <span class="spinner-border spinner-border-sm d-none" role="status"
                    aria-hidden="true" data-region="spinner"></span>
                <span data-region="btnlabel">{{#str}}btn_generate_outline, local_studiolms{{/str}}</span>
            </button>
        </div>
    </form>
</div>
