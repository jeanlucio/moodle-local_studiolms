{{!
    @template local_studiolms/wizard_section

    Three-step section generator: briefing → activity plan review → generation + report.

    Context variables required for this template:
    * courseid - Target course id.
    * sections - Array of {num, name} course sections.

    Example context (json):
    {
        "courseid": 5,
        "sections": [
            {"num": 0, "name": "General"},
            {"num": 1, "name": "Section 1"}
        ]
    }
}}
<div class="local-studiolms-wizard d-none" id="local-studiolms-section"
     data-aria-type="{{#str}}aria_activity_type, local_studiolms{{/str}}"
     data-aria-title="{{#str}}aria_activity_title, local_studiolms{{/str}}"
     data-aria-remove="{{#str}}aria_remove_activity, local_studiolms{{/str}}">

    {{! Step 1: Briefing form }}
    <div data-region="form-view">
        <h3 class="mb-3">{{#str}}section_heading, local_studiolms{{/str}}</h3>

        <form id="local-studiolms-section-form" data-courseid="{{courseid}}">

            <div class="alert alert-danger d-none" role="alert" data-region="error"></div>

            <div class="mb-3">
                <label class="form-label" for="section-sectionnum">
                    {{#str}}activity_section, local_studiolms{{/str}}
                </label>
                <select class="form-select" id="section-sectionnum" name="sectionnum">
                    <option value="-1">{{#str}}section_new, local_studiolms{{/str}}</option>
                    {{#sections}}
                        <option value="{{num}}">{{name}}</option>
                    {{/sections}}
                </select>
            </div>

            <div class="mb-3 d-none" data-region="wipe-option">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="section-wipe" name="wipe"
                           aria-describedby="section-wipe-warning">
                    <label class="form-check-label" for="section-wipe">
                        {{#str}}section_wipe, local_studiolms{{/str}}
                    </label>
                </div>
                <div id="section-wipe-warning"
                     class="alert alert-warning mt-2 mb-0 py-2 small d-none"
                     data-region="wipe-warning">
                    {{#str}}section_wipe_warning, local_studiolms{{/str}}
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label" for="section-theme">
                    {{#str}}briefing_theme, local_studiolms{{/str}}
                    <span class="text-danger" aria-hidden="true">*</span>
                </label>
                <input type="text" class="form-control" id="section-theme" name="theme" required
                    placeholder="{{#str}}briefing_theme_placeholder, local_studiolms{{/str}}">
            </div>

            <div class="mb-3">
                <label class="form-label" for="section-reference">
                    {{#str}}briefing_reference, local_studiolms{{/str}}
                </label>
                <textarea class="form-control" id="section-reference" name="reference" rows="4"
                    placeholder="{{#str}}briefing_reference_placeholder, local_studiolms{{/str}}"></textarea>
            </div>

            <div class="d-flex justify-content-start">
                <button type="button" class="btn btn-secondary me-2" data-action="back-to-landing">
                    {{#str}}btn_back, local_studiolms{{/str}}
                </button>
                <button type="submit" class="btn btn-primary" data-action="plan-section">
                    <span class="spinner-border spinner-border-sm d-none" role="status"
                          aria-hidden="true" data-region="spinner"></span>
                    <span data-region="btnlabel">
                        {{#str}}btn_plan_section, local_studiolms{{/str}}
                    </span>
                </button>
            </div>

        </form>
    </div>

    {{! Step 2: Activity plan review }}
    <div data-region="review-view" class="d-none">
        <h3 class="mb-3">{{#str}}section_plan_heading, local_studiolms{{/str}}</h3>

        <div class="alert alert-danger d-none" role="alert" data-region="review-error"></div>

        <div data-region="activity-list" class="mb-3"></div>

        <button type="button" class="btn btn-outline-secondary btn-sm mb-3"
                data-action="add-activity">
            {{#str}}section_plan_add, local_studiolms{{/str}}
        </button>

        <div class="d-flex justify-content-start">
            <button type="button" class="btn btn-secondary me-2" data-action="back-to-form">
                {{#str}}btn_back, local_studiolms{{/str}}
            </button>
            <button type="button" class="btn btn-primary" data-action="generate-section">
                <span class="spinner-border spinner-border-sm d-none" role="status"
                      aria-hidden="true" data-region="review-spinner"></span>
                <span data-region="review-btnlabel">
                    {{#str}}btn_generate_section, local_studiolms{{/str}}
                </span>
            </button>
        </div>
    </div>

    {{! Step 3: Progress and report }}
    <div data-region="progress-view" class="d-none">
        <h3 class="mb-3">{{#str}}section_heading, local_studiolms{{/str}}</h3>

        <div class="progress mb-2">
            <div class="progress-bar progress-bar-striped progress-bar-animated"
                 role="progressbar" data-region="bar"
                 aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"
                 aria-label="{{#str}}section_heading, local_studiolms{{/str}}"></div>
        </div>
        <p class="text-muted small mb-3" data-region="progress-message">
            {{#str}}section_planning, local_studiolms{{/str}}
        </p>

        <div class="mb-3 d-none" data-region="report"></div>

        <div class="alert alert-success d-none" role="status" data-region="done">
            <p class="mb-2">{{#str}}section_success, local_studiolms{{/str}}</p>
            <div class="d-flex flex-wrap">
                <a href="#" class="btn btn-sm btn-success me-2"
                   data-region="viewlink" target="_blank" rel="noopener">
                    {{#str}}section_view, local_studiolms{{/str}}
                </a>
                <button type="button" class="btn btn-sm btn-outline-secondary"
                        data-action="generate-another">
                    {{#str}}section_generate_another, local_studiolms{{/str}}
                </button>
            </div>
        </div>

        <div class="alert alert-danger d-none" role="alert" data-region="progress-error"></div>
    </div>

</div>
