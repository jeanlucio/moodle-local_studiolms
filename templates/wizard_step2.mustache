{{!
    @template local_studiolms/wizard_step2

    Course review step of the StudioLMS course builder wizard. Objectives,
    sections and activities can be renamed, removed or added before the course
    is populated.

    Context variables required for this template:
    * outlineid - Stored outline id.
    * courseid - Target course id.
    * cancelurl - URL back to the course.
    * steplabel - "Step 2 of 3" label.
    * hasobjectives - Whether there is at least one objective.
    * objectives - Array of objective strings.
    * sections - Array of {title, activities: [{title, typeoptions: [{value, label, selected}]}]}.
    * activitytypes - Array of {value, label} used for newly added activities.

    Example context (json):
    {
        "outlineid": 7,
        "courseid": 5,
        "cancelurl": "https://example.com/course/view.php?id=5",
        "steplabel": "Step 2 of 3",
        "hasobjectives": true,
        "objectives": ["Apply core concepts to real problems."],
        "sections": [
            {
                "title": "Fundamentals",
                "activities": [
                    {
                        "title": "What is the topic?",
                        "typeoptions": [
                            {"value": "page", "label": "Page", "selected": true},
                            {"value": "quiz", "label": "Quiz", "selected": false}
                        ]
                    }
                ]
            }
        ],
        "activitytypes": [
            {"value": "page", "label": "Page"},
            {"value": "quiz", "label": "Quiz"}
        ]
    }
}}
<div class="local-studiolms-wizard" data-outlineid="{{outlineid}}" data-courseid="{{courseid}}">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">{{#str}}outline_review_heading, local_studiolms{{/str}}</h3>
        <span class="badge bg-light text-dark border">{{steplabel}}</span>
    </div>

    <div class="card mb-3">
        <div class="card-header h6 mb-0">{{#str}}objectives_heading, local_studiolms{{/str}}</div>
        <ul class="list-group list-group-flush" data-region="objectives">
            {{#objectives}}
                <li class="list-group-item d-flex align-items-center" data-region="objective">
                    <input type="text" class="form-control flex-fill me-2" value="{{.}}"
                        data-field="objective" aria-label="{{#str}}aria_objective, local_studiolms{{/str}}">
                    <button type="button" class="btn btn-outline-danger btn-sm" data-action="remove-objective"
                        aria-label="{{#str}}aria_remove_objective, local_studiolms{{/str}}">
                        <i class="icon fa fa-trash m-0" aria-hidden="true"></i>
                    </button>
                </li>
            {{/objectives}}
        </ul>
        <div class="card-body py-2">
            <button type="button" class="btn btn-sm btn-outline-primary" data-action="add-objective">
                {{#str}}add_objective, local_studiolms{{/str}}
            </button>
        </div>
    </div>

    <div data-region="sections">
        {{#sections}}
            <div class="card mb-3" data-region="section">
                <div class="card-header d-flex align-items-center">
                    <span class="badge bg-light text-dark border me-2" data-region="sectionnum"></span>
                    <input type="text" class="form-control flex-fill me-2" value="{{title}}"
                        data-field="sectiontitle" aria-label="{{#str}}aria_section_title, local_studiolms{{/str}}">
                    <button type="button" class="btn btn-outline-danger btn-sm" data-action="remove-section"
                        aria-label="{{#str}}aria_remove_section, local_studiolms{{/str}}">
                        <i class="icon fa fa-trash m-0" aria-hidden="true"></i>
                    </button>
                </div>
                <ul class="list-group list-group-flush" data-region="activities">
                    {{#activities}}
                        <li class="list-group-item d-flex align-items-center" data-region="activity">
                            <select class="form-select form-select-sm w-auto me-2" data-field="activitytype"
                                aria-label="{{#str}}aria_activity_type, local_studiolms{{/str}}">
                                {{#typeoptions}}
                                    <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                                {{/typeoptions}}
                            </select>
                            <input type="text" class="form-control flex-fill me-2" value="{{title}}"
                                data-field="activitytitle"
                                aria-label="{{#str}}aria_activity_title, local_studiolms{{/str}}">
                            <button type="button" class="btn btn-outline-danger btn-sm" data-action="remove-activity"
                                aria-label="{{#str}}aria_remove_activity, local_studiolms{{/str}}">
                                <i class="icon fa fa-trash m-0" aria-hidden="true"></i>
                            </button>
                        </li>
                    {{/activities}}
                </ul>
                <div class="card-body py-2">
                    <button type="button" class="btn btn-sm btn-outline-primary" data-action="add-activity">
                        {{#str}}add_activity, local_studiolms{{/str}}
                    </button>
                </div>
            </div>
        {{/sections}}
    </div>

    <div class="mb-3">
        <button type="button" class="btn btn-outline-primary" data-action="add-section">
            {{#str}}add_section, local_studiolms{{/str}}
        </button>
    </div>

    <p class="text-muted small mb-2 d-none" data-region="estimate" aria-live="polite"></p>

    <div class="d-flex justify-content-start align-items-center">
        <button type="button" class="btn btn-secondary me-2" data-action="back">
            {{#str}}btn_back, local_studiolms{{/str}}
        </button>
        <a class="btn btn-outline-secondary me-2" href="{{cancelurl}}">
            {{#str}}btn_cancel, local_studiolms{{/str}}
        </a>
        <button type="button" class="btn btn-primary" data-action="populate">
            <span class="spinner-border spinner-border-sm d-none" role="status"
                aria-hidden="true" data-region="spinner"></span>
            <span data-region="populatelabel">{{#str}}btn_populate, local_studiolms{{/str}}</span>
        </button>
    </div>

    <template data-template="objective">
        <li class="list-group-item d-flex align-items-center" data-region="objective">
            <input type="text" class="form-control flex-fill me-2" value=""
                data-field="objective" aria-label="{{#str}}aria_objective, local_studiolms{{/str}}">
            <button type="button" class="btn btn-outline-danger btn-sm" data-action="remove-objective"
                aria-label="{{#str}}aria_remove_objective, local_studiolms{{/str}}">
                <i class="icon fa fa-trash m-0" aria-hidden="true"></i>
            </button>
        </li>
    </template>

    <template data-template="activity">
        <li class="list-group-item d-flex align-items-center" data-region="activity">
            <select class="form-select form-select-sm w-auto me-2" data-field="activitytype"
                aria-label="{{#str}}aria_activity_type, local_studiolms{{/str}}">
                {{#activitytypes}}
                    <option value="{{value}}">{{label}}</option>
                {{/activitytypes}}
            </select>
            <input type="text" class="form-control flex-fill me-2" value=""
                data-field="activitytitle" aria-label="{{#str}}aria_activity_title, local_studiolms{{/str}}">
            <button type="button" class="btn btn-outline-danger btn-sm" data-action="remove-activity"
                aria-label="{{#str}}aria_remove_activity, local_studiolms{{/str}}">
                <i class="icon fa fa-trash m-0" aria-hidden="true"></i>
            </button>
        </li>
    </template>

    <template data-template="section">
        <div class="card mb-3" data-region="section">
            <div class="card-header d-flex align-items-center">
                <span class="badge bg-light text-dark border me-2" data-region="sectionnum"></span>
                <input type="text" class="form-control flex-fill me-2" value=""
                    data-field="sectiontitle" aria-label="{{#str}}aria_section_title, local_studiolms{{/str}}">
                <button type="button" class="btn btn-outline-danger btn-sm" data-action="remove-section"
                    aria-label="{{#str}}aria_remove_section, local_studiolms{{/str}}">
                    <i class="icon fa fa-trash m-0" aria-hidden="true"></i>
                </button>
            </div>
            <ul class="list-group list-group-flush" data-region="activities"></ul>
            <div class="card-body py-2">
                <button type="button" class="btn btn-sm btn-outline-primary" data-action="add-activity">
                    {{#str}}add_activity, local_studiolms{{/str}}
                </button>
            </div>
        </div>
    </template>
</div>
