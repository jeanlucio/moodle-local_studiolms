{{!
    @template local_studiolms/wizard_step3

    Generation progress step of the StudioLMS course builder wizard.

    Context variables required for this template:
    * steplabel - "Step 3 of 3" label.

    Example context (json):
    {
        "steplabel": "Step 3 of 3"
    }
}}
<div class="local-studiolms-wizard">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">{{#str}}populate_heading, local_studiolms{{/str}}</h3>
        <span class="badge bg-light text-dark border">{{steplabel}}</span>
    </div>

    <div class="progress mb-3">
        <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar"
            data-region="bar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0"></div>
    </div>

    <p data-region="message" aria-live="polite"></p>

    <div class="alert alert-danger d-none" role="alert" data-region="error"></div>

    <div class="alert alert-warning d-none" role="alert" data-region="warnings"></div>

    <div class="mt-3 d-none" data-region="report"></div>

    <div class="d-none mt-3" data-region="done">
        <a class="btn btn-primary" href="#" data-region="backtocourse">
            {{#str}}back_to_course, local_studiolms{{/str}}
        </a>
    </div>
</div>
