{{!
    @template local_studiolms/wizard_landing

    Mode selection landing page for the StudioLMS course builder.

    Context variables required for this template:
    * cancelurl - URL back to the course.

    Example context (json):
    {
        "cancelurl": "https://example.com/course/view.php?id=5",
        "logourl": "https://example.com/pluginfile.php/1/local_studiolms/pix/logo.svg",
        "landingheading": "Hello Jane, what would you like to do today?"
    }
}}
<div class="local-studiolms-wizard" id="local-studiolms-landing">
    <div class="text-center mb-4">
        <div class="d-flex align-items-center justify-content-center mb-2">
            <img src="{{logourl}}" alt="StudioLMS"
                 class="studiolms-landing-logo me-3" width="48" height="48">
            <span class="studiolms-landing-brand">StudioLMS</span>
        </div>
        <p class="studiolms-landing-greeting mb-0">{{landingheading}}</p>
    </div>

    <div class="row mb-4">
        <div class="col-12 col-md-4 mb-3">
            <div class="card h-100 shadow-sm border-primary">
                <div class="card-body d-flex flex-column">
                    <div class="mb-3 text-primary" aria-hidden="true">
                        <i class="fa fa-cube fa-2x"></i>
                    </div>
                    <h5 class="card-title">{{#str}}landing_activity_title, local_studiolms{{/str}}</h5>
                    <p class="card-text text-muted flex-grow-1">
                        {{#str}}landing_activity_desc, local_studiolms{{/str}}
                    </p>
                    <button type="button" class="btn btn-primary mt-3"
                            data-action="select-mode" data-mode="activity">
                        {{#str}}landing_activity_title, local_studiolms{{/str}}
                    </button>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-4 mb-3">
            <div class="card h-100 shadow-sm border-primary">
                <div class="card-body d-flex flex-column">
                    <div class="mb-3 text-primary" aria-hidden="true">
                        <i class="fa fa-list-alt fa-2x"></i>
                    </div>
                    <h5 class="card-title">{{#str}}landing_section_title, local_studiolms{{/str}}</h5>
                    <p class="card-text text-muted flex-grow-1">
                        {{#str}}landing_section_desc, local_studiolms{{/str}}
                    </p>
                    <button type="button" class="btn btn-primary mt-3"
                            data-action="select-mode" data-mode="section">
                        {{#str}}landing_section_title, local_studiolms{{/str}}
                    </button>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-4 mb-3">
            <div class="card h-100 shadow-sm border-primary">
                <div class="card-body d-flex flex-column">
                    <div class="mb-3 text-primary" aria-hidden="true">
                        <i class="fa fa-graduation-cap fa-2x"></i>
                    </div>
                    <h5 class="card-title">{{#str}}landing_course_title, local_studiolms{{/str}}</h5>
                    <p class="card-text text-muted flex-grow-1">
                        {{#str}}landing_course_desc, local_studiolms{{/str}}
                    </p>
                    <button type="button" class="btn btn-primary mt-3"
                            data-action="select-mode" data-mode="course">
                        {{#str}}landing_course_title, local_studiolms{{/str}}
                    </button>
                </div>
            </div>
        </div>
    </div>

    <a class="btn btn-secondary" href="{{cancelurl}}">
        {{#str}}btn_cancel, local_studiolms{{/str}}
    </a>
</div>
