<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/studiolms/db" VERSION="20260613" COMMENT="XMLDB file for the local_studiolms plugin."
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="local_studiolms_generation_log" COMMENT="Audit record for each course generation run.">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Teacher who ran the generation."/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Target course filled by the generation."/>
        <FIELD NAME="mode" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="standard" SEQUENCE="false" COMMENT="standard or gamified."/>
        <FIELD NAME="bloomlevel" TYPE="char" LENGTH="20" NOTNULL="false" SEQUENCE="false" COMMENT="Selected Bloom's taxonomy level."/>
        <FIELD NAME="gamificationprofile" TYPE="char" LENGTH="20" NOTNULL="false" SEQUENCE="false" COMMENT="conquest, narrative, social or null."/>
        <FIELD NAME="prompt" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="Theme or prompt provided by the teacher."/>
        <FIELD NAME="outlinejson" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="JSON of the approved outline."/>
        <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="completed" SEQUENCE="false" COMMENT="completed, failed or cancelled."/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="timecompleted" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="userid" UNIQUE="false" FIELDS="userid"/>
        <INDEX NAME="courseid" UNIQUE="false" FIELDS="courseid"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_studiolms_outline" COMMENT="Draft outline persisted between wizard steps.">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Teacher who owns the draft."/>
        <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="draft" SEQUENCE="false" COMMENT="draft, reviewed or completed."/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Target course (the wizard runs in its context)."/>
        <FIELD NAME="briefingjson" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="JSON of step 1 (theme, mode, level, wipe opt-in)."/>
        <FIELD NAME="outlinejson" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="JSON generated by the AI plus teacher edits."/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="useridcourseid" UNIQUE="false" FIELDS="userid, courseid"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_studiolms_progress" COMMENT="Background generation progress polled by step 3.">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="outlineid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="FK to local_studiolms_outline."/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Teacher (validates polling access)."/>
        <FIELD NAME="step" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Current completed step."/>
        <FIELD NAME="total" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Total planned steps."/>
        <FIELD NAME="message" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false" COMMENT="Current step message."/>
        <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="queued" SEQUENCE="false" COMMENT="queued, running, completed or failed."/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Target course of the generation."/>
        <FIELD NAME="createditems" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="JSON of created ids (sectionids, cmids) for surgical rollback."/>
        <FIELD NAME="errormsg" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="Error message when status is failed."/>
        <FIELD NAME="warnings" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="JSON list of activities that used simplified content."/>
        <FIELD NAME="reportjson" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="JSON array of per-activity generation report (title, type, preset, degraded)."/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="outlineid" TYPE="foreign" FIELDS="outlineid" REFTABLE="local_studiolms_outline" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="userid" UNIQUE="false" FIELDS="userid"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
